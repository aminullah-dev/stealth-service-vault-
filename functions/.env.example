# Non-secret config for the SafeBeauty Cloud Functions.
# Copy to functions/.env and adjust if HesabPay gives you a different base URL.
# (Secrets — HESAB_API_KEY, HESAB_WEBHOOK_SECRET — are NOT stored here; set them
#  with `firebase functions:secrets:set`.)

HESAB_BASE_URL=https://api.hesab.com/api/v1
