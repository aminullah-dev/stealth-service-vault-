rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // The app's own uid scheme (the client-generated UUID that is the actual
    // users/{uid} document ID — see RegisterViewModel) is NOT the same value
    // as request.auth.uid (Firebase Auth's own, separately-generated uid).
    // uid_map/{request.auth.uid} bridges the two (written by syncUidMap /
    // resolveAppUser in Cloud Functions right after sign-in) so every rule
    // below that compares against a stored customerId/providerId/etc. — all
    // of which are the app-level uid — resolves correctly.
    function me() {
      return get(/databases/$(database)/documents/uid_map/$(request.auth.uid)).data.appUid;
    }

    function myData() {
      return get(/databases/$(database)/documents/users/$(me())).data;
    }

    function isAdmin() {
      return isSignedIn() && myData().role == 'ADMIN';
    }

    function isProvider() {
      return isSignedIn() && myData().role == 'PROVIDER';
    }

    function isCustomer() {
      return isSignedIn() && myData().role == 'CUSTOMER';
    }

    function isApproved() {
      return isSignedIn() && myData().status == 'APPROVED';
    }

    function ownsDoc(uid) {
      return isSignedIn() && me() == uid;
    }

    // Returns true if the current user is the provider who owns [salonId].
    function ownsThisSalon(salonId) {
      return isProvider()
          && get(/databases/$(database)/documents/salons/$(salonId)).data.providerId == me();
    }

    // conversationId format: "{customerId}_{salonId}"
    // Returns true if the current user is the customer OR the salon's provider.
    function isParticipantInConversation(conversationId) {
      let parts = conversationId.split('_');
      return parts.size() >= 2
          && (parts[0] == me()
              || get(/databases/$(database)/documents/salons/$(parts[1])).data.providerId == me());
    }

    // ── users ──────────────────────────────────────────────────────────────────
    //
    // Login and the pre-auth phone lookup are now Cloud Functions
    // (authenticateWithPin / lookupAccountByPhone) that run with the Admin SDK
    // and bypass these rules. Clients therefore never need to read the users
    // collection pre-auth, so reads are locked down: a user may read only their
    // OWN document, and only an admin may list users. This closes the previous
    // hole where the entire credential table (every pinHash/salt) was readable.
    //
    match /users/{uid} {
      allow get:  if isSignedIn() && (ownsDoc(uid) || isAdmin());
      allow list: if isAdmin();

      // {uid} is a UUID the CLIENT generates at registration (see
      // RegisterViewModel) — independent of Firebase Auth's own uid, and
      // uid_map (which backs me()) can't be populated yet at this point
      // anyway, since it's only ever written by looking up an EXISTING
      // users/{uid} doc. So this can't check "me() == uid"; what actually
      // prevents hijacking someone else's profile is Firestore's own
      // create-vs-update semantics (this rule only ever fires for a document
      // that doesn't exist yet — a colliding UUID is cryptographically
      // negligible) plus the role/status constraints below. A self-registration
      // may ONLY be a CUSTOMER (auto-approved) or a PROVIDER (starts PENDING,
      // awaiting admin approval) — never an ADMIN, and a provider may not
      // self-approve. The first ADMIN is bootstrapped out-of-band (console /
      // setup), not through this path.
      allow create: if isSignedIn()
                 && (
                      (request.resource.data.role == 'CUSTOMER'
                       && request.resource.data.status == 'APPROVED')
                   || (request.resource.data.role == 'PROVIDER'
                       && request.resource.data.status == 'PENDING')
                    );

      // Users can update their own profile; admins can change status / verify.
      // A self-update may NOT change privileged fields — role and status are
      // admin-controlled. Without this, any user could set role='ADMIN' or
      // un-suspend themselves (status='APPROVED') by writing their own doc.
      // pinHash/salt stay editable here (the Change-PIN flow verifies the old
      // PIN first); name/photo/loyaltyPoints/fcmToken remain editable too.
      allow update: if isAdmin()
                 || (ownsDoc(uid)
                     && request.resource.data.role   == resource.data.role
                     && request.resource.data.status == resource.data.status);

      allow delete: if isAdmin();
    }

    // ── salons ─────────────────────────────────────────────────────────────────
    match /salons/{salonId} {
      allow read: if isSignedIn();

      // Salons are created exclusively by the createProviderSalon Cloud Function
      // (Admin SDK bypasses these rules). It runs at registration — before the
      // uid_map bridge exists — so me() can't resolve here, and the providerId
      // must be set authoritatively server-side (to the app-level uid) rather
      // than trusted from the client.
      allow create: if false;

      // Provider can edit their own salon; admin can edit any.
      // A provider may NOT flip isVerified — the VERIFIED badge is a trust signal
      // granted only by an admin (setSalonVerified). Without this guard a provider
      // could self-award the badge to look legitimate.
      allow update: if isAdmin()
                 || (isProvider() && isApproved()
                     && resource.data.providerId == me()
                     && request.resource.data.providerId == resource.data.providerId
                     && request.resource.data.isVerified  == resource.data.isVerified);

      allow delete: if isAdmin()
                 || (isProvider() && resource.data.providerId == me());
    }

    // ── appointments ───────────────────────────────────────────────────────────
    match /appointments/{apptId} {
      // Readable only by the customer who booked, the salon's provider, or admin.
      allow read: if isSignedIn()
               && (resource.data.customerId == me()
                   || ownsThisSalon(resource.data.salonId)
                   || isAdmin());

      // Appointments are created exclusively by the createPaymentSession Cloud
      // Function (Admin SDK bypasses these rules). This enforces pay-first: a
      // client cannot create a booking without going through HesabPay payment.
      allow create: if false;

      // Provider confirms or reschedules their salon's appointment directly, but
      // may ONLY touch status + appointmentDate — never the customer's identity
      // (customerId/customerName/customerPhone) or the price/service — and may
      // NOT set status to CANCELLED. Admin is unrestricted.
      //
      // Neither customer NOR provider cancellation is allowed via a direct
      // write here — every PENDING/CONFIRMED appointment has already been paid
      // (the webhook only advances out of AWAITING_PAYMENT after payment
      // succeeds), so a direct status flip to CANCELLED would leave the
      // payment marked PAID with no refund record. Both must go through
      // cancelAppointment / providerDeclineAppointment, which cancel AND
      // create a refund_requests entry (Admin SDK bypasses this rule).
      allow update: if isAdmin()
                 || (ownsThisSalon(resource.data.salonId)
                     && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['status', 'appointmentDate'])
                     && request.resource.data.customerId == resource.data.customerId
                     && request.resource.data.status != 'CANCELLED');

      allow delete: if isAdmin();
    }

    // ── chat_messages ──────────────────────────────────────────────────────────
    // conversationId = "{customerId}_{salonId}"
    // Messages are immutable once sent.
    match /chat_messages/{msgId} {
      allow read: if isSignedIn()
               && isParticipantInConversation(resource.data.conversationId);

      allow create: if isSignedIn()
                 && request.resource.data.senderId == me()
                 && isParticipantInConversation(request.resource.data.conversationId);

      allow update, delete: if false;
    }

    // ── reviews ────────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if isSignedIn();

      // Customers submit reviews for themselves.
      allow create: if isCustomer() && isApproved()
                 && request.resource.data.customerId == me();

      // Provider may only add/edit their reply (no other fields may change).
      allow update: if (ownsThisSalon(resource.data.salonId)
                        && request.resource.data.diff(resource.data).affectedKeys()
                               .hasOnly(['providerReply', 'repliedAt']))
                 || isAdmin();

      allow delete: if isAdmin();
    }

    // ── salon_gallery ──────────────────────────────────────────────────────────
    match /salon_gallery/{imageId} {
      allow read: if isSignedIn();

      allow create: if isProvider() && isApproved()
                 && ownsThisSalon(request.resource.data.salonId);

      // Images are replaced by delete + re-upload; no in-place edits.
      allow update: if false;

      allow delete: if ownsThisSalon(resource.data.salonId) || isAdmin();
    }

    // ── broadcasts ─────────────────────────────────────────────────────────────
    match /broadcasts/{docId} {
      allow read:                    if isSignedIn();
      allow create, update, delete:  if isAdmin();
    }

    // ── waitlist ───────────────────────────────────────────────────────────────
    match /waitlist/{entryId} {
      allow read: if isSignedIn()
               && (resource.data.customerId == me()
                   || ownsThisSalon(resource.data.salonId)
                   || isAdmin());

      allow create: if isCustomer() && isApproved()
                 && request.resource.data.customerId == me();

      // Provider marks slot as available; admin can do anything.
      allow update: if ownsThisSalon(resource.data.salonId) || isAdmin();

      allow delete: if resource.data.customerId == me() || isAdmin();
    }

    // ── notifications ──────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Each user sees only their own notifications.
      allow read: if isSignedIn()
               && (resource.data.recipientId == me() || isAdmin());

      // Created exclusively by the Cloud Functions (Admin SDK bypasses these
      // rules). Every notification doc becomes a real FCM push
      // (pushOnNotificationCreated), so an open client create path would let
      // any signed-in user push arbitrary text to any user's phone.
      allow create: if false;

      // Only the recipient marks as read / deletes.
      allow update: if resource.data.recipientId == me() || isAdmin();
      allow delete: if resource.data.recipientId == me() || isAdmin();
    }

    // ── payments ─────────────────────────────────────────────────────────────
    // Written exclusively by the payment Cloud Functions (Admin SDK bypasses
    // these rules). Clients may only READ their own payment to observe status.
    match /payments/{paymentId} {
      allow read: if isSignedIn()
               && (resource.data.customerId == me()
                   || resource.data.providerId == me()
                   || isAdmin());
      allow write: if false;
    }

    // ── processed_webhooks ───────────────────────────────────────────────────────
    // Replay-guard ledger keyed by HesabPay transaction_id. Written exclusively
    // by the hesabPayWebhook Cloud Function (Admin SDK). No client access.
    match /processed_webhooks/{transactionId} {
      allow read, write: if false;
    }

    // ── refund_requests ─────────────────────────────────────────────────────────
    // Created exclusively by the cancelAppointment Cloud Function (Admin SDK)
    // when a customer cancels a PAID booking. The customer/provider involved can
    // see their own request; only admin can read all / will process it manually
    // (no automated HesabPay refund API is wired yet).
    match /refund_requests/{requestId} {
      allow read: if isSignedIn()
               && (resource.data.customerId == me()
                   || resource.data.providerId == me()
                   || isAdmin());
      allow write: if false;
    }

    // ── platform_config ────────────────────────────────────────────────────────
    // Global settings (e.g. commissionPercent). Readable by signed-in users;
    // writable only by admins. The payment function reads it server-side.
    match /platform_config/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── provider_balances ───────────────────────────────────────────────────────
    // Ledger of what each provider is owed. Maintained by the webhook Cloud
    // Function; a provider may read only their own balance.
    match /provider_balances/{providerId} {
      allow read:  if ownsDoc(providerId) || isAdmin();
      allow write: if false;
    }

    // ── payouts ─────────────────────────────────────────────────────────────────
    // History of platform→provider payments. Written exclusively by the
    // recordProviderPayout Cloud Function (Admin SDK). A provider reads only
    // their own payouts; admins read all.
    match /payouts/{payoutId} {
      allow read:  if isSignedIn()
               && (resource.data.providerId == me() || isAdmin());
      allow write: if false;
    }

    // ── uid_map ─────────────────────────────────────────────────────────────────
    // Bridges request.auth.uid to the app's own uid scheme (see me()). Written
    // exclusively by syncUidMap / resolveAppUser (Admin SDK, Cloud Functions).
    // No client access — it's read only via the internal get() inside me(),
    // which is not subject to this (or any) document's own rules.
    match /uid_map/{authUid} {
      allow read, write: if false;
    }
  }
}
