<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher background: a soft ivory-to-blush radial wash that matches the
  SafeBeauty brand (ElegantCream #FFF8F0 -> BlushPink). Keeps the rose
  foreground reading as warm and premium on the home screen.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="48"
                android:gradientRadius="78"
                android:startColor="#FFFDF9"
                android:centerColor="#FBEFEA"
                android:endColor="#F3D8DE" />
        </aapt:attr>
    </path>
</vector>
