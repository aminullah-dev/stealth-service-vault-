rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
          && firestore.get(
               /databases/(default)/documents/users/$(request.auth.uid)
             ).data.role == 'ADMIN';
    }

    function salonOwner(salonId) {
      return isSignedIn()
          && firestore.get(
               /databases/(default)/documents/salons/$(salonId)
             ).data.providerId == request.auth.uid;
    }

    function isValidImage() {
      return request.resource.size  < 2 * 1024 * 1024    // max 2 MB
          // Raster formats only — 'image/.*' would also accept image/svg+xml,
          // which is XML and can carry scripts (stored-XSS if ever rendered).
          && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // ── Profile photos ─────────────────────────────────────────────────────────
    // Path: profile_photos/{uid}.jpg
    // Storage Rules path segments can't mix a wildcard capture with a literal
    // suffix (e.g. "{uid}.jpg" is invalid syntax) — so the whole segment is
    // captured as fileName and checked against "<uid>.jpg" in the rule body.
    match /profile_photos/{fileName} {
      allow read:   if isSignedIn();
      allow write:  if isSignedIn()
                  && fileName == request.auth.uid + '.jpg'
                  && isValidImage();
    }

    // ── Salon gallery ──────────────────────────────────────────────────────────
    // Path: salon_gallery/{salonId}/{imageId}.jpg
    match /salon_gallery/{salonId}/{imageId} {
      allow read:   if isSignedIn();
      allow create: if salonOwner(salonId) && isValidImage();
      allow update: if false;                    // replace by delete + re-upload
      allow delete: if salonOwner(salonId) || isAdmin();
    }
  }
}
